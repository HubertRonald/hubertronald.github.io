{
    "name": "hubertronald-github-io",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vitepress dev docs",
        "build": "vitepress build docs && npm run static:copy",
        "preview": "vitepress preview docs",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs && npm run static:copy",
        "docs:preview": "vitepress preview docs",
        "static:copy": "node scripts/copy-static-sites.mjs",
        "relationalstats:fetch": "rm -rf .vendor/relationalstats && mkdir -p .vendor && git clone --depth 1 https://github.com/HubertRonald/relationalstats.git .vendor/relationalstats",
        "relationalstats:sync": "RELATIONALSTATS_REPO=.vendor/relationalstats node scripts/sync-relationalstats-docs.mjs",
        "relationalstats:update": "npm run relationalstats:fetch && npm run relationalstats:sync"
    },
    "devDependencies": {
        "gray-matter": "^4.0.3",
        "markdown-it-mathjax3": "^4.3.2",
        "mermaid": "^11.15.0",
        "vitepress": "1.6.4",
        "vitepress-plugin-mermaid": "^2.0.17"
    }
}